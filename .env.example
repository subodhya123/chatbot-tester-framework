# Environment variables for ChatBot Tester Framework
# Copy this file to .env and fill in your values

# Authentication
CHATBOT_BEARER_TOKEN=your-bearer-token-here
CHATBOT_API_KEY=your-api-key-here
CHATBOT_USERNAME=your-username
CHATBOT_PASSWORD=your-password
CHATBOT_CLIENT_ID=your-client-id
CHATBOT_CLIENT_SECRET=your-client-secret
CHATBOT_CUSTOM_AUTH=your-custom-header-value

# OAuth2 Scope (space-separated)
CHATBOT_OAUTH_SCOPE=chatbot:read chatbot:write

# Override config file path
# CHATBOT_TEST_CONFIG=/path/to/custom-config.yaml

# Chatbot URL
CHATBOT_BASE_URL=http://localhost:8000